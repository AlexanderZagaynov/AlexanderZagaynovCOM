---
import BaseLayout from '../layouts/BaseLayout.astro'
import {
  chromeWebStoreUrl,
  contactEmail,
  githubUrl,
  linkedInUrl,
} from '../lib/links'

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
const path = (value: string) => `${baseUrl}${value.replace(/^\//, '')}`
const description =
  'Alexander Zagaynov is a lead software engineer focused on enterprise modernization, cloud systems, reliability, security, CI/CD, and local-first software projects.'
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Alexander Zagaynov',
    url: 'https://alexander-zagaynov.com/',
    email: `mailto:${contactEmail}`,
    sameAs: [linkedInUrl, githubUrl],
    jobTitle: 'Lead Software Engineer',
    knowsAbout: [
      'Enterprise modernization',
      'Cloud engineering',
      'Ruby on Rails',
      'Spring Boot',
      'Vue.js',
      'Kubernetes',
      'Security engineering',
      'CI/CD',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Alexander Zagaynov',
    url: 'https://alexander-zagaynov.com/',
    inLanguage: 'en-US',
  },
]
---

<BaseLayout title="Alexander Zagaynov - Lead Software Engineer" description={description} schema={schema}>
  <section class="hero personal-hero shell home-section">
    <div class="hero-copy">
      <h1>Alexander Zagaynov</h1>
      <p class="lead">
        Lead Software Engineer building and modernizing production systems
        across enterprise, fintech, and cloud environments.
      </p>
      <div class="actions">
        <a class="button primary" href={path('/cv/')}>View CV</a>
        <a class="button" href={`mailto:${contactEmail}`}>Contact</a>
      </div>
    </div>
    <aside class="hero-panel" aria-label="Engineering profile summary">
      <dl class="signal-list">
        <div>
          <dt>Experience</dt>
          <dd>25+ years</dd>
        </div>
        <div>
          <dt>Focus</dt>
          <dd>Modernization, reliability, security, CI/CD</dd>
        </div>
        <div>
          <dt>Current role</dt>
          <dd>Lead Software Engineer at AT&amp;T</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section id="about" class="section shell about-section home-section" data-home-section>
    <div class="section-kicker">About</div>
    <div class="section-layout">
      <div>
        <h2>Systems work that respects production reality.</h2>
      </div>
      <div class="prose-lite">
        <p>
          I work hands-on across backend, frontend, and infrastructure, with a
          bias toward reducing operational risk and making legacy systems easier
          to change. My recent work includes Java/Kotlin and Vue modernization,
          identity integration with Microsoft Entra ID, security hardening,
          production incident resolution, and Azure DevOps CI/CD delivery.
        </p>
        <p>
          Earlier roles at EPAM, Red Hat, Mamapedia, and independent consulting
          gave me a broad base across banking platforms, open-source cloud
          systems, Rails applications, ERP/WMS/CRM implementations, and
          enterprise infrastructure.
        </p>
      </div>
    </div>
  </section>

  <section id="projects" class="section shell projects-section home-section" data-home-section>
    <div class="section-heading-row">
      <div>
        <div class="section-kicker">Projects</div>
        <!-- <h2>Selected work and local-first tools.</h2> -->
      </div>
    </div>

    <article class="project-feature">
      <div class="project-copy">
        <img
          class="project-icon"
          src={path('/assets/icons/latertabs-icon128.png')}
          width="128"
          height="128"
          alt=""
        />
        <h3>LaterTabs</h3>
        <p>
          A local-first Chrome extension for saving open tabs, restoring tab
          sessions, and searching saved browser context without accounts,
          analytics, or a backend.
        </p>
        <div class="actions">
          <a class="button primary" href={path('/latertabs/')}>View project</a>
          <a class="button" href={chromeWebStoreUrl}>Chrome Web Store</a>
        </div>
      </div>
      <figure class="project-media">
        <img
          src={path('/assets/promotional/latertabs-marquee-1400x560.png')}
          width="1400"
          height="560"
          alt="LaterTabs promotional graphic showing browser tabs saved into organized sessions"
        />
      </figure>
    </article>
  </section>
</BaseLayout>
