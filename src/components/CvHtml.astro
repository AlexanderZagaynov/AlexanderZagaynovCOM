---
import { cvPdfPath, githubUrl, linkedInUrl } from '../lib/links'

interface Props {
  showPageLink?: boolean
}

const { showPageLink = true } = Astro.props
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
const path = (value: string) => `${baseUrl}${value.replace(/^\//, '')}`

const skills = [
  ['Languages', 'Ruby, Python, Java, Kotlin, JavaScript, TypeScript, SQL, Bash'],
  ['Frameworks', 'Ruby on Rails, Spring Boot, Vue.js'],
  ['Cloud & DevOps', 'Azure, AWS, GCP, Kubernetes, Docker, Terraform, Ansible, Azure DevOps, Jenkins, GitHub Actions'],
  ['Data & Messaging', 'PostgreSQL, MySQL, MongoDB, Redis, Kafka, RabbitMQ, REST, GraphQL, SOAP/WSDL'],
  ['Security & Quality', 'Microsoft Entra ID, TLS/PKI, internal CA, WAF, SonarQube, Veracode'],
]

const experience = [
  {
    role: 'Lead Software Engineer',
    company: 'AT&T',
    period: 'Oct 2023 - Present',
    details: [
      'Hands-on modernization and support of 2 large enterprise applications (Java/Kotlin, Spring Boot, Vue.js, TypeScript) plus supporting internal services.',
      'Migrated major applications from Spring Boot 2 to 4 and Vue 2 to 3, and modernized 3 Python legacy services, reducing technical debt and improving maintainability.',
      'Integrated Microsoft Entra ID, strengthened TLS/PKI, internal CA, and WAF-related security, integrated SonarQube and Veracode, and designed Azure DevOps CI/CD pipelines.',
    ],
  },
  {
    role: 'Lead Software Engineer',
    company: 'EPAM Systems',
    period: 'Apr 2020 - May 2023',
    details: [
      'Worked with a European banking platform vendor and two live banks in high-load, regulated environments across engineering, SRE, integration, and production support.',
      'Resolved critical production incidents across dozens of Ruby- and Java-based microservices, including one approximately 100x speedup; investigated unfamiliar codebases in Java, Python, Go, Swift, and Ruby.',
      'Delivered PSD2 integrations across REST/JSON, SOAP/WSDL, and messaging; modernized Rails services and CI/CD pipelines; supported release readiness, RCA, and mentoring.',
    ],
  },
  {
    role: 'Software Engineer',
    company: 'Red Hat',
    period: 'Dec 2016 - Jan 2020',
    details: [
      'Contributed to OpenShift QE and ManageIQ hybrid cloud platform development.',
      'Built test frameworks, led AWS STS integration, upgraded SDKs, and contributed to AWS, Azure, and GCP cloud integrations.',
      'Worked as an active open-source contributor across code, reviews, and upstream collaboration.',
    ],
  },
  {
    role: 'Full-Stack Engineer',
    company: 'Mamapedia',
    period: '2015 - 2016',
    details: [
      'Modernized a legacy Rails 2.x platform on Ruby 1.8.7, improving rendering performance by about 2x, and added AJAX-powered instant search with improved Apache Solr integration.',
      'Improved security with encrypted passwords and tokenized password resets, rebuilt the personalized daily email digest system, and automated AWS deployments with Capistrano, Salt, and Terraform.',
    ],
  },
  {
    role: 'ERP & Infrastructure Consultant',
    company: 'Independent and client work',
    period: '1998 - 2014',
    details: [
      'Delivered ERP, WMS, CRM, and enterprise infrastructure solutions across multiple industries, including custom business platforms and data-center modernization projects.',
    ],
  },
]
---

<div class="cv-document">
  <header class="cv-heading">
    <div>
      <h2>Alexander Zagaynov</h2>
      <p>
        Lead Software Engineer with 25+ years of experience modernizing
        production systems across enterprise, fintech, cloud, and
        infrastructure environments, with a focus on legacy transformation,
        reliability, CI/CD, and security hardening.
      </p>
    </div>
    <div class="cv-actions">
      <a class="button primary" href={path(cvPdfPath)} download>Download PDF</a>
      {showPageLink && <a class="button" href={path('/cv/')}>Open CV page</a>}
    </div>
  </header>

  <section class="cv-block" aria-labelledby="cv-contact">
    <h3 id="cv-contact">Contact</h3>
    <ul class="inline-list">
      <li><a href="mailto:zalex80@gmail.com">zalex80@gmail.com</a></li>
      <li><a href="tel:+420775282001">+420 775 282 001</a></li>
      <li><a href={linkedInUrl}>LinkedIn</a></li>
      <li><a href={githubUrl}>GitHub</a></li>
    </ul>
  </section>

  <section class="cv-block" aria-labelledby="cv-skills">
    <h3 id="cv-skills">Core Skills</h3>
    <dl class="skill-list">
      {
        skills.map(([label, value]) => (
          <>
            <dt>{label}</dt>
            <dd>{value}</dd>
          </>
        ))
      }
    </dl>
  </section>

  <section class="cv-block" aria-labelledby="cv-certifications">
    <h3 id="cv-certifications">Certifications</h3>
    <p>
      Microsoft Certified: DevOps Engineer Expert, Azure Administrator
      Associate, and Azure AI Fundamentals; AWS Certified Solutions Architect -
      Associate; Red Hat Certified Engineer, Red Hat Certified System
      Administrator, and Red Hat Certified Specialist in Ansible Automation.
    </p>
  </section>

  <section class="cv-block" aria-labelledby="cv-experience">
    <h3 id="cv-experience">Experience</h3>
    <div class="timeline">
      {
        experience.map((item) => (
          <article class="timeline-item">
            <div>
              <h4>{item.role} · {item.company}</h4>
              <p>{item.period}</p>
            </div>
            <ul>
              {item.details.map((detail) => <li>{detail}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="cv-block" aria-labelledby="cv-development">
    <h3 id="cv-development">Professional Development</h3>
    <p>IT Project Management, I Heart Stats (Notre Dame, edX), Entrepreneurship 101 (edX).</p>
  </section>
</div>
